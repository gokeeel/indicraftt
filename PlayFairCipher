#include<stdio.h>
#include<string.h>
#include<ctype.h>

char m[5][5];

void pos(char ch, int *r, int *c)
{
    int i, j;
    if(ch == 'J') ch = 'I';

    for(i = 0; i < 5; i++)
        for(j = 0; j < 5; j++)
            if(m[i][j] == ch)
            {
                *r = i;
                *c = j;
                return;
            }
}

int main()
{
    char key[20], txt[50], u[25], a, b, ch;
    int used[26] = {0}, i, j, k = 0, len;
    int r1, c1, r2, c2;

    // Removed clrscr() to prevent online compiler errors

    used['J' - 'A'] = 1;

    printf("Enter keyword: ");
    scanf("%s", key);

    printf("Enter plain text: ");
    scanf("%s", txt);

    for(i = 0; key[i] != '\0'; i++)
    {
        ch = toupper(key[i]);
        if(ch == 'J') ch = 'I';

        if(!used[ch - 'A'])
        {
            u[k++] = ch;
            used[ch - 'A'] = 1;
        }
    }

    for(i = 0; i < k; i++)
        m[i / 5][i % 5] = u[i];

    for(i = 0; i < 26; i++)
        if(!used[i])
            m[k / 5][k % 5] = i + 'A', k++;

    printf("\nKey Matrix:\n");
    for(i = 0; i < 5; i++)
    {
        for(j = 0; j < 5; j++)
            printf("%c ", m[i][j]);
        printf("\n");
    }

    for(i = 0; txt[i] != '\0'; i++)
    {
        txt[i] = toupper(txt[i]);
        if(txt[i] == 'J') txt[i] = 'I';
    }

    printf("\nCipher Text: ");
    len = strlen(txt);

    for(i = 0; i < len; i += 2)
    {
        a = txt[i];
        b = (i + 1 < len) ? txt[i + 1] : 'X';
        if(a == b) b = 'X';

        pos(a, &r1, &c1);
        pos(b, &r2, &c2);

        if(r1 == r2)
            printf("%c%c", m[r1][(c1 + 1) % 5], m[r2][(c2 + 1) % 5]);
        else if(c1 == c2)
            printf("%c%c", m[(r1 + 1) % 5][c1], m[(r2 + 1) % 5][c2]);
        else
            printf("%c%c", m[r1][c2], m[r2][c1]);
    }

    printf("\n"); // Cleaner output formatting
    return 0;
}
